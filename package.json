{
  "name": "opencode-sidebar-tui-sage",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "2.2.1",
  "publisher": "sagez",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.106.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "opencode",
    "terminal",
    "sidebar",
    "tui",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sage-z-cn/opencode-sidebar-tui.git"
  },
  "license": "MIT",
  "author": {
    "name": "sagez"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "ostContainer",
          "title": "%views.container.title%",
          "icon": "resources/opencode-activity-bar.svg"
        }
      ]
    },
    "views": {
      "ostContainer": [
        {
          "id": "ost",
          "name": "%views.terminal.name%",
          "type": "webview",
          "icon": "resources/opencode-activity-bar.svg",
          "initialOrder": 1
        }
      ]
    },
    "commands": [
      {
        "command": "ost.start",
          "title": "%command.ost.start.title%",
          "category": "%command.category.ost%"
      },
      {
        "command": "ost.focus",
          "title": "%command.ost.focus.title%"
      },
      {
        "command": "ost.sendToTerminal",
          "title": "%command.ost.sendToTerminal.title%",
          "category": "%command.category.ost%"
      },
      {
        "command": "ost.sendAtMention",
          "title": "%command.ost.sendAtMention.title%",
          "category": "%command.category.ost%"
      },
      {
        "command": "ost.sendAllOpenFiles",
          "title": "%command.ost.sendAllOpenFiles.title%",
          "category": "%command.category.ost%"
      },
      {
        "command": "ost.sendFileToTerminal",
          "title": "%command.ost.sendFileToTerminal.title%",
          "category": "%command.category.ost%"
      },
      {
        "command": "ost.paste",
          "title": "%command.ost.paste.title%",
          "category": "%command.category.ost%",
        "icon": "$(clippy)"
      },
      {
        "command": "ost.openInNewWindow",
          "title": "%command.ost.openInNewWindow.title%",
          "category": "%command.category.ost%",
        "icon": "$(empty-window)"
      },
      {
        "command": "ost.spawnForWorkspace",
          "title": "%command.ost.spawnForWorkspace.title%",
          "category": "%command.category.ost%",
        "icon": "$(add)"
      },
      {
        "command": "ost.selectInstance",
          "title": "%command.ost.selectInstance.title%",
          "category": "%command.category.ost%",
        "icon": "$(server-environment)"
      },
      {
        "command": "ost.switchTmuxSession",
          "title": "%command.ost.switchTmuxSession.title%",
          "category": "%command.category.ost%"
      },
      {
        "command": "ost.createTmuxSession",
          "title": "%command.ost.createTmuxSession.title%"
      },
      {
        "command": "ost.browseTmuxSessions",
          "title": "%command.ost.browseTmuxSessions.title%",
          "category": "%command.category.ost%",
        "icon": "$(server-environment)"
      },
      {
        "command": "ost.switchNativeShell",
          "title": "%command.ost.switchNativeShell.title%",
          "category": "%command.category.ost%"
      },
      {
        "command": "ost.killNativeShell",
          "title": "%command.ost.killNativeShell.title%"
      },
      {
        "command": "ost.openTerminalManager",
          "title": "%command.ost.openTerminalManager.title%",
          "category": "%command.category.ost%",
        "icon": "$(server)"
      },
      {
        "command": "ost.toggleDashboard",
          "title": "%command.ost.toggleDashboard.title%",
          "category": "%command.category.ost%",
        "icon": "$(dashboard)"
      },
      {
        "command": "ost.toggleTmuxCommandToolbar",
          "title": "%command.ost.toggleTmuxCommandToolbar.title%",
          "category": "%command.category.ost%",
        "icon": "$(list-tree)"
      },
      {
        "command": "ost.openDashboardInEditor",
          "title": "%command.ost.openDashboardInEditor.title%",
          "category": "%command.category.ost%",
        "icon": "$(editor-layout)"
      },
      {
        "command": "ost.openTerminalInEditor",
          "title": "%command.ost.openTerminalInEditor.title%",
          "category": "%command.category.ost%",
        "icon": {
          "light": "resources/opencode-activity-bar.svg",
          "dark": "resources/opencode-activity-bar-dark.svg"
        }
      },
      {
        "command": "ost.restoreTerminalToSidebar",
          "title": "%command.ost.restoreTerminalToSidebar.title%",
          "category": "%command.category.ost%",
        "icon": "$(layout-sidebar-left)"
      },
      {
        "command": "ost.tmuxSwitchPane",
          "title": "%command.ost.tmuxSwitchPane.title%",
          "category": "%command.category.ost%",
        "icon": "$(check)"
      },
      {
        "command": "ost.tmuxSplitPaneH",
          "title": "%command.ost.tmuxSplitPaneH.title%",
          "category": "%command.category.ost%",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "ost.tmuxSplitPaneV",
          "title": "%command.ost.tmuxSplitPaneV.title%",
          "category": "%command.category.ost%",
        "icon": "$(split-vertical)"
      },
      {
        "command": "ost.tmuxSplitPaneWithCommand",
          "title": "%command.ost.tmuxSplitPaneWithCommand.title%",
          "category": "%command.category.ost%",
        "icon": "$(terminal)"
      },
      {
        "command": "ost.tmuxSendTextToPane",
          "title": "%command.ost.tmuxSendTextToPane.title%",
          "category": "%command.category.ost%",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "ost.tmuxResizePane",
          "title": "%command.ost.tmuxResizePane.title%",
          "category": "%command.category.ost%",
        "icon": "$(move)"
      },
      {
        "command": "ost.tmuxSwapPane",
          "title": "%command.ost.tmuxSwapPane.title%",
          "category": "%command.category.ost%",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "ost.tmuxKillPane",
          "title": "%command.ost.tmuxKillPane.title%",
          "category": "%command.category.ost%",
        "icon": "$(trash)"
      },
      {
        "command": "ost.tmuxNextWindow",
          "title": "%command.ost.tmuxNextWindow.title%",
          "category": "%command.category.ost%",
        "icon": "$(chevron-right)"
      },
      {
        "command": "ost.tmuxPrevWindow",
          "title": "%command.ost.tmuxPrevWindow.title%",
          "category": "%command.category.ost%",
        "icon": "$(chevron-left)"
      },
      {
        "command": "ost.tmuxCreateWindow",
          "title": "%command.ost.tmuxCreateWindow.title%",
          "category": "%command.category.ost%",
        "icon": "$(add)"
      },
      {
        "command": "ost.tmuxKillWindow",
          "title": "%command.ost.tmuxKillWindow.title%",
          "category": "%command.category.ost%",
        "icon": "$(trash)"
      },
      {
        "command": "ost.tmuxSelectWindow",
          "title": "%command.ost.tmuxSelectWindow.title%",
          "category": "%command.category.ost%",
        "icon": "$(list-selection)"
      },
      {
        "command": "ost.tmuxKillSession",
          "title": "%command.ost.tmuxKillSession.title%",
          "category": "%command.category.ost%",
        "icon": "$(trash)"
      },
      {
        "command": "ost.killTmuxSession",
          "title": "%command.ost.killTmuxSession.title%"
      },
      {
        "command": "ost.tmuxRefresh",
        "title": "%command.ost.tmuxRefresh.title%",
        "category": "%command.category.ost%",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [],
      "editor/title": [
        {
          "command": "ost.openTerminalManager",
          "group": "navigation",
          "when": "ost.active"
        },
        {
          "command": "ost.openTerminalInEditor",
          "group": "navigation@1",
          "when": "ost.active"
        }
      ],
      "explorer/context": [
        {
          "command": "ost.sendFileToTerminal",
          "group": "2_workspace",
          "when": "!explorerResourceIsFolder"
        },
        {
          "command": "ost.sendFileToTerminal",
          "group": "2_workspace",
          "when": "explorerResourceIsFolder"
        }
      ],
      "editor/context": [
        {
          "command": "ost.sendAtMention",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ost.sendAtMention",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "when": "editorTextFocus || terminalFocus"
      },
      {
        "command": "ost.sendAllOpenFiles",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a",
        "when": "editorTextFocus || terminalFocus"
      },
      {
        "command": "ost.browseTmuxSessions",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t",
        "when": "focusedView == 'ost'"
      },
      {
        "command": "-workbench.action.quickOpen",
        "key": "ctrl+p",
        "when": "focusedView == 'ost'"
      },
      {
        "command": "-workbench.action.quickOpenNavigateNextInFilePicker",
        "key": "ctrl+p",
        "when": "inFilesPicker && inQuickOpen"
      },
      {
        "command": "ost.paste",
        "key": "ctrl+v",
        "mac": "cmd+v",
        "when": "focusedView == 'ost'"
      },
      {
        "command": "ost.toggleTmuxCommandToolbar",
        "key": "ctrl+alt+m",
        "mac": "cmd+alt+m",
        "when": "focusedView == 'ost'"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "ost.fontSize": {
          "type": "number",
          "default": 12,
          "minimum": 6,
          "maximum": 25,
          "description": "%configuration.ost.fontSize.description%"
        },
        "ost.fontFamily": {
          "type": "string",
          "default": "'JetBrainsMono Nerd Font', 'FiraCode Nerd Font', 'CascadiaCode NF', Menlo, monospace",
          "description": "%configuration.ost.fontFamily.description%"
        },
        "ost.cursorBlink": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ost.cursorBlink.description%"
        },
        "ost.cursorStyle": {
          "type": "string",
          "default": "block",
          "enum": [
            "block",
            "underline",
            "bar"
          ],
          "description": "%configuration.ost.cursorStyle.description%"
        },
        "ost.scrollback": {
          "type": "number",
          "default": 10000,
          "minimum": 0,
          "maximum": 100000,
          "description": "%configuration.ost.scrollback.description%"
        },
        "ost.autoFocusOnSend": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ost.autoFocusOnSend.description%"
        },
        "ost.autoStartOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ost.autoStartOnOpen.description%"
        },
        "ost.shellPath": {
          "type": "string",
          "default": "",
          "description": "%configuration.ost.shellPath.description%"
        },
        "ost.shellArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%configuration.ost.shellArgs.description%"
        },
        "ost.sendKeybindingsToShell": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ost.sendKeybindingsToShell.description%"
        },
        "ost.showTmuxWindowControls": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ost.showTmuxWindowControls.description%"
        },
        "ost.autoShareContext": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ost.autoShareContext.description%"
        },
        "ost.httpTimeout": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "maximum": 30000,
          "description": "%configuration.ost.httpTimeout.description%"
        },
        "ost.enableHttpApi": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ost.enableHttpApi.description%"
        },
        "ost.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "default": "info",
          "description": "%configuration.ost.logLevel.description%"
        },
        "ost.contextDebounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 5000,
          "description": "%configuration.ost.contextDebounceMs.description%"
        },
        "ost.maxDiagnosticLength": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 2000,
          "description": "%configuration.ost.maxDiagnosticLength.description%"
        },
        "ost.enableAutoSpawn": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ost.enableAutoSpawn.description%"
        },
        "ost.terminalBackend": {
          "type": "string",
          "default": "tmux",
          "enum": [
            "native",
            "tmux",
            "zellij"
          ],
          "enumDescriptions": [
            "%configuration.ost.terminalBackend.enumDescription.native%",
            "%configuration.ost.terminalBackend.enumDescription.tmux%",
            "%configuration.ost.terminalBackend.enumDescription.zellij%"
          ],
          "description": "%configuration.ost.terminalBackend.description%",
          "order": 1
        },
        "ost.collapseSecondaryBarOnEditorOpen": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ost.collapseSecondaryBarOnEditorOpen.description%"
        },
        "ost.codeActionSeverities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "error",
              "warning",
              "information",
              "hint"
            ]
          },
          "default": [
            "error",
            "warning"
          ],
          "description": "%configuration.ost.codeActionSeverities.description%"
        },
        "ost.aiTools": {
          "type": "array",
          "items": {
            "type": "object",
            "editPresentation": "editButton",
            "required": [
              "name",
              "label"
            ],
            "order": [
              "name",
              "label",
              "path",
              "args",
              "aliases",
              "operator"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "%configuration.ost.aiTools.items.name.description%"
              },
              "label": {
                "type": "string",
                "description": "%configuration.ost.aiTools.items.label.description%"
              },
              "path": {
                "type": "string",
                "description": "%configuration.ost.aiTools.items.path.description%"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "%configuration.ost.aiTools.items.args.description%"
              },
              "aliases": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "%configuration.ost.aiTools.items.aliases.description%"
              },
              "operator": {
                "type": "string",
                "description": "%configuration.ost.aiTools.items.operator.description%"
              }
            }
          },
          "default": [
            {
              "name": "opencode",
              "label": "OpenCode",
              "path": "",
              "args": [],
              "operator": "opencode"
            },
            {
              "name": "claude",
              "label": "Claude",
              "path": "",
              "args": [],
              "aliases": [
                "claude"
              ],
              "operator": "claude"
            },
            {
              "name": "codex",
              "label": "Codex",
              "path": "",
              "args": [],
              "operator": "codex"
            }
          ],
          "description": "%configuration.ost.aiTools.description%"
        },
        "ost.defaultAiTool": {
          "type": "string",
          "default": "opencode",
          "description": "%configuration.ost.defaultAiTool.description%"
        },
        "ost.promptAiToolOnSession": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ost.promptAiToolOnSession.description%"
        },
        "ost.pane.defaultSplitDirection": {
          "type": "string",
          "default": "horizontal",
          "enum": ["horizontal", "vertical"],
          "description": "%configuration.ost.pane.defaultSplitDirection.description%"
        },
        "ost.pane.focusOnClick": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ost.pane.focusOnClick.description%"
        },
        "ost.pane.showPaneActions": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ost.pane.showPaneActions.description%"
        },
        "ost.pane.renderer": {
          "type": "string",
          "default": "auto",
          "enum": ["webgl", "canvas", "auto"],
          "description": "%configuration.ost.pane.renderer.description%"
        }
      }
    }
  },
  "scripts": {
    "compile": "webpack",
    "compile:e2e": "tsc -p tsconfig.e2e.json",
    "watch": "webpack --watch",
    "package": "npx @vscode/vsce package -o build/extension.vsix",
    "lint": "eslint src --ext ts",
    "format": "prettier --write \"src/**/*.{ts,js,json,css,md}\"",
    "test": "vitest run",
    "pretest:e2e": "npm run compile && npm run compile:e2e",
    "test:e2e": "vscode-test",
    "test:all": "npm run test && npm run test:e2e",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build-and-install": "node scripts/build-and-install.js"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.2.0-beta.11",
    "preact": "^10.29.1"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.13",
    "@types/vscode": "^1.106.1",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.5.4",
    "jsdom": "^29.0.1",
    "mocha": "^11.7.5",
    "prettier": "^3.7.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.0"
  }
}

