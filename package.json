{
  "name": "ai-sidebar-terminal",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "2.4.2",
  "publisher": "sagez",
  "icon": "icon.png",
  "l10n": "./l10n",
  "engines": {
    "vscode": "^1.106.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ai",
    "agent",
    "terminal",
    "tui",
    "sidebar",
    "opencode",
    "claude",
    "codex",
    "gemini",
    "kimi",
    "multi-agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sage-z-cn/ai-sidebar-terminal.git"
  },
  "license": "MIT",
  "author": {
    "name": "sagez"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "ai-sidebar-terminalContainer",
          "title": "%views.container.title%",
          "icon": "resources/activity-bar.svg"
        }
      ]
    },
    "views": {
      "ai-sidebar-terminalContainer": [
        {
          "id": "ai-sidebar-terminal-view",
          "name": "%views.terminal.name%",
          "type": "webview",
          "icon": "resources/activity-bar.svg",
          "initialOrder": 1
        }
      ]
    },
    "commands": [
      {
        "command": "ai-sidebar-terminal.start",
        "title": "%command.ai-sidebar-terminal.start.title%",
        "category": "%command.category.ai-sidebar-terminal%"
      },
      {
        "command": "ai-sidebar-terminal.focus",
        "title": "%command.ai-sidebar-terminal.focus.title%"
      },
      {
        "command": "ai-sidebar-terminal.sendToTerminal",
        "title": "%command.ai-sidebar-terminal.sendToTerminal.title%",
        "category": "%command.category.ai-sidebar-terminal%"
      },
      {
        "command": "ai-sidebar-terminal.sendAtMention",
        "title": "%command.ai-sidebar-terminal.sendAtMention.title%",
        "category": "%command.category.ai-sidebar-terminal%"
      },
      {
        "command": "ai-sidebar-terminal.sendAllOpenFiles",
        "title": "%command.ai-sidebar-terminal.sendAllOpenFiles.title%",
        "category": "%command.category.ai-sidebar-terminal%"
      },
      {
        "command": "ai-sidebar-terminal.sendToAiTerminal",
        "title": "%command.ai-sidebar-terminal.sendToAiTerminal.title%",
        "category": "%command.category.ai-sidebar-terminal%"
      },
      {
        "command": "ai-sidebar-terminal.paste",
        "title": "%command.ai-sidebar-terminal.paste.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(clippy)"
      },
      {
        "command": "ai-sidebar-terminal.openInNewWindow",
        "title": "%command.ai-sidebar-terminal.openInNewWindow.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(empty-window)"
      },
      {
        "command": "ai-sidebar-terminal.spawnForWorkspace",
        "title": "%command.ai-sidebar-terminal.spawnForWorkspace.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(add)"
      },
      {
        "command": "ai-sidebar-terminal.selectInstance",
        "title": "%command.ai-sidebar-terminal.selectInstance.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(server-environment)"
      },
      {
        "command": "ai-sidebar-terminal.switchTmuxSession",
        "title": "%command.ai-sidebar-terminal.switchTmuxSession.title%",
        "category": "%command.category.ai-sidebar-terminal%"
      },
      {
        "command": "ai-sidebar-terminal.createTmuxSession",
        "title": "%command.ai-sidebar-terminal.createTmuxSession.title%"
      },
      {
        "command": "ai-sidebar-terminal.browseTmuxSessions",
        "title": "%command.ai-sidebar-terminal.browseTmuxSessions.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(server-environment)"
      },
      {
        "command": "ai-sidebar-terminal.switchNativeShell",
        "title": "%command.ai-sidebar-terminal.switchNativeShell.title%",
        "category": "%command.category.ai-sidebar-terminal%"
      },
      {
        "command": "ai-sidebar-terminal.killNativeShell",
        "title": "%command.ai-sidebar-terminal.killNativeShell.title%"
      },
      {
        "command": "ai-sidebar-terminal.openTerminalManager",
        "title": "%command.ai-sidebar-terminal.openTerminalManager.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(server)"
      },
      {
        "command": "ai-sidebar-terminal.toggleDashboard",
        "title": "%command.ai-sidebar-terminal.toggleDashboard.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(dashboard)"
      },
      {
        "command": "ai-sidebar-terminal.toggleTmuxCommandToolbar",
        "title": "%command.ai-sidebar-terminal.toggleTmuxCommandToolbar.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(list-tree)"
      },
      {
        "command": "ai-sidebar-terminal.openDashboardInEditor",
        "title": "%command.ai-sidebar-terminal.openDashboardInEditor.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(editor-layout)"
      },
      {
        "command": "ai-sidebar-terminal.openTerminalInEditor",
        "title": "%command.ai-sidebar-terminal.openTerminalInEditor.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": {
          "light": "resources/activity-bar.svg",
          "dark": "resources/activity-bar.svg"
        }
      },
      {
        "command": "ai-sidebar-terminal.restoreTerminalToSidebar",
        "title": "%command.ai-sidebar-terminal.restoreTerminalToSidebar.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(layout-sidebar-left)"
      },
      {
        "command": "ai-sidebar-terminal.tmuxSwitchPane",
        "title": "%command.ai-sidebar-terminal.tmuxSwitchPane.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(check)"
      },
      {
        "command": "ai-sidebar-terminal.tmuxSplitPaneH",
        "title": "%command.ai-sidebar-terminal.tmuxSplitPaneH.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "ai-sidebar-terminal.tmuxSplitPaneV",
        "title": "%command.ai-sidebar-terminal.tmuxSplitPaneV.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(split-vertical)"
      },
      {
        "command": "ai-sidebar-terminal.tmuxSplitPaneWithCommand",
        "title": "%command.ai-sidebar-terminal.tmuxSplitPaneWithCommand.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(terminal)"
      },
      {
        "command": "ai-sidebar-terminal.tmuxSendTextToPane",
        "title": "%command.ai-sidebar-terminal.tmuxSendTextToPane.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "ai-sidebar-terminal.tmuxResizePane",
        "title": "%command.ai-sidebar-terminal.tmuxResizePane.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(move)"
      },
      {
        "command": "ai-sidebar-terminal.tmuxSwapPane",
        "title": "%command.ai-sidebar-terminal.tmuxSwapPane.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "ai-sidebar-terminal.tmuxKillPane",
        "title": "%command.ai-sidebar-terminal.tmuxKillPane.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(trash)"
      },
      {
        "command": "ai-sidebar-terminal.tmuxNextWindow",
        "title": "%command.ai-sidebar-terminal.tmuxNextWindow.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(chevron-right)"
      },
      {
        "command": "ai-sidebar-terminal.tmuxPrevWindow",
        "title": "%command.ai-sidebar-terminal.tmuxPrevWindow.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(chevron-left)"
      },
      {
        "command": "ai-sidebar-terminal.tmuxCreateWindow",
        "title": "%command.ai-sidebar-terminal.tmuxCreateWindow.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(add)"
      },
      {
        "command": "ai-sidebar-terminal.tmuxKillWindow",
        "title": "%command.ai-sidebar-terminal.tmuxKillWindow.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(trash)"
      },
      {
        "command": "ai-sidebar-terminal.tmuxSelectWindow",
        "title": "%command.ai-sidebar-terminal.tmuxSelectWindow.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(list-selection)"
      },
      {
        "command": "ai-sidebar-terminal.tmuxKillSession",
        "title": "%command.ai-sidebar-terminal.tmuxKillSession.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(trash)"
      },
      {
        "command": "ai-sidebar-terminal.killTmuxSession",
        "title": "%command.ai-sidebar-terminal.killTmuxSession.title%"
      },
      {
        "command": "ai-sidebar-terminal.tmuxRefresh",
        "title": "%command.ai-sidebar-terminal.tmuxRefresh.title%",
        "category": "%command.category.ai-sidebar-terminal%",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [],
      "editor/title": [
        {
          "command": "ai-sidebar-terminal.openTerminalManager",
          "group": "navigation",
          "when": "ai-sidebar-terminal.active"
        },
        {
          "command": "ai-sidebar-terminal.openTerminalInEditor",
          "group": "navigation@1",
          "when": "ai-sidebar-terminal.active"
        }
      ],
      "explorer/context": [
        {
          "command": "ai-sidebar-terminal.sendToAiTerminal",
          "group": "2_workspace",
          "when": "!explorerResourceIsFolder"
        },
        {
          "command": "ai-sidebar-terminal.sendToAiTerminal",
          "group": "2_workspace",
          "when": "explorerResourceIsFolder"
        }
      ],
      "editor/context": [
        {
          "command": "ai-sidebar-terminal.sendAtMention",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ai-sidebar-terminal.sendAtMention",
        "key": "alt+a",
        "mac": "alt+a",
        "when": "editorTextFocus || terminalFocus"
      },
      {
        "command": "ai-sidebar-terminal.sendAllOpenFiles",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a",
        "when": "editorTextFocus || terminalFocus"
      },
      {
        "command": "ai-sidebar-terminal.browseTmuxSessions",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t",
        "when": "focusedView == 'ai-sidebar-terminal-view'"
      },
      {
        "command": "-workbench.action.quickOpen",
        "key": "ctrl+p",
        "when": "focusedView == 'ai-sidebar-terminal-view'"
      },
      {
        "command": "-workbench.action.quickOpenNavigateNextInFilePicker",
        "key": "ctrl+p",
        "when": "inFilesPicker && inQuickOpen"
      },
      {
        "command": "ai-sidebar-terminal.paste",
        "key": "ctrl+v",
        "mac": "cmd+v",
        "when": "focusedView == 'ai-sidebar-terminal-view'"
      },
      {
        "command": "ai-sidebar-terminal.toggleTmuxCommandToolbar",
        "key": "ctrl+alt+m",
        "mac": "cmd+alt+m",
        "when": "focusedView == 'ai-sidebar-terminal-view'"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "ai-sidebar-terminal.fontSize": {
          "type": "number",
          "default": 12,
          "minimum": 6,
          "maximum": 25,
          "description": "%configuration.ai-sidebar-terminal.fontSize.description%"
        },
        "ai-sidebar-terminal.fontFamily": {
          "type": "string",
          "default": "'JetBrainsMono Nerd Font', 'FiraCode Nerd Font', 'CascadiaCode NF', Menlo, monospace",
          "description": "%configuration.ai-sidebar-terminal.fontFamily.description%"
        },
        "ai-sidebar-terminal.cursorBlink": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ai-sidebar-terminal.cursorBlink.description%"
        },
        "ai-sidebar-terminal.cursorStyle": {
          "type": "string",
          "default": "block",
          "enum": [
            "block",
            "underline",
            "bar"
          ],
          "description": "%configuration.ai-sidebar-terminal.cursorStyle.description%"
        },
        "ai-sidebar-terminal.scrollback": {
          "type": "number",
          "default": 10000,
          "minimum": 0,
          "maximum": 100000,
          "description": "%configuration.ai-sidebar-terminal.scrollback.description%"
        },
        "ai-sidebar-terminal.autoFocusOnSend": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ai-sidebar-terminal.autoFocusOnSend.description%"
        },
        "ai-sidebar-terminal.autoStartOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ai-sidebar-terminal.autoStartOnOpen.description%"
        },
        "ai-sidebar-terminal.shellPath": {
          "type": "string",
          "default": "",
          "description": "%configuration.ai-sidebar-terminal.shellPath.description%"
        },
        "ai-sidebar-terminal.shellArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%configuration.ai-sidebar-terminal.shellArgs.description%"
        },
        "ai-sidebar-terminal.sendKeybindingsToShell": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ai-sidebar-terminal.sendKeybindingsToShell.description%"
        },
        "ai-sidebar-terminal.showTmuxWindowControls": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ai-sidebar-terminal.showTmuxWindowControls.description%"
        },
        "ai-sidebar-terminal.autoShareContext": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ai-sidebar-terminal.autoShareContext.description%"
        },
        "ai-sidebar-terminal.httpTimeout": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "maximum": 30000,
          "description": "%configuration.ai-sidebar-terminal.httpTimeout.description%"
        },
        "ai-sidebar-terminal.enableHttpApi": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ai-sidebar-terminal.enableHttpApi.description%"
        },
        "ai-sidebar-terminal.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "default": "info",
          "description": "%configuration.ai-sidebar-terminal.logLevel.description%"
        },
        "ai-sidebar-terminal.contextDebounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 5000,
          "description": "%configuration.ai-sidebar-terminal.contextDebounceMs.description%"
        },
        "ai-sidebar-terminal.maxDiagnosticLength": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 2000,
          "description": "%configuration.ai-sidebar-terminal.maxDiagnosticLength.description%"
        },
        "ai-sidebar-terminal.enableAutoSpawn": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ai-sidebar-terminal.enableAutoSpawn.description%"
        },
        "ai-sidebar-terminal.terminalBackend": {
          "type": "string",
          "default": "native",
          "enum": [
            "native",
            "tmux",
            "zellij"
          ],
          "enumDescriptions": [
            "%configuration.ai-sidebar-terminal.terminalBackend.enumDescription.native%",
            "%configuration.ai-sidebar-terminal.terminalBackend.enumDescription.tmux%",
            "%configuration.ai-sidebar-terminal.terminalBackend.enumDescription.zellij%"
          ],
          "description": "%configuration.ai-sidebar-terminal.terminalBackend.description%",
          "order": 1
        },
        "ai-sidebar-terminal.collapseSecondaryBarOnEditorOpen": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ai-sidebar-terminal.collapseSecondaryBarOnEditorOpen.description%"
        },
        "ai-sidebar-terminal.codeActionSeverities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "error",
              "warning",
              "information",
              "hint"
            ]
          },
          "default": [
            "error",
            "warning"
          ],
          "description": "%configuration.ai-sidebar-terminal.codeActionSeverities.description%"
        },
        "ai-sidebar-terminal.aiTools": {
          "type": "array",
          "items": {
            "type": "object",
            "editPresentation": "editButton",
            "required": [
              "name",
              "label"
            ],
            "order": [
              "name",
              "label",
              "path",
              "args",
              "aliases",
              "operator"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "%configuration.ai-sidebar-terminal.aiTools.items.name.description%"
              },
              "label": {
                "type": "string",
                "description": "%configuration.ai-sidebar-terminal.aiTools.items.label.description%"
              },
              "path": {
                "type": "string",
                "description": "%configuration.ai-sidebar-terminal.aiTools.items.path.description%"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "%configuration.ai-sidebar-terminal.aiTools.items.args.description%"
              },
              "aliases": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "%configuration.ai-sidebar-terminal.aiTools.items.aliases.description%"
              },
              "operator": {
                "type": "string",
                "description": "%configuration.ai-sidebar-terminal.aiTools.items.operator.description%"
              }
            }
          },
          "default": [
            {
              "name": "opencode",
              "label": "OpenCode",
              "path": "",
              "args": [],
              "operator": "opencode"
            },
            {
              "name": "claude",
              "label": "Claude",
              "path": "",
              "args": [],
              "aliases": [
                "claude"
              ],
              "operator": "claude"
            },
            {
              "name": "codex",
              "label": "Codex",
              "path": "",
              "args": [],
              "operator": "codex"
            }
          ],
          "description": "%configuration.ai-sidebar-terminal.aiTools.description%"
        },
        "ai-sidebar-terminal.defaultAiTool": {
          "type": "string",
          "default": "opencode",
          "description": "%configuration.ai-sidebar-terminal.defaultAiTool.description%"
        },
        "ai-sidebar-terminal.promptAiToolOnSession": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ai-sidebar-terminal.promptAiToolOnSession.description%"
        },
        "ai-sidebar-terminal.pane.defaultSplitDirection": {
          "type": "string",
          "default": "horizontal",
          "enum": [
            "horizontal",
            "vertical"
          ],
          "description": "%configuration.ai-sidebar-terminal.pane.defaultSplitDirection.description%"
        },
        "ai-sidebar-terminal.pane.focusOnClick": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ai-sidebar-terminal.pane.focusOnClick.description%"
        },
        "ai-sidebar-terminal.pane.showPaneActions": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.ai-sidebar-terminal.pane.showPaneActions.description%"
        },
        "ai-sidebar-terminal.pane.renderer": {
          "type": "string",
          "default": "auto",
          "enum": [
            "webgl",
            "canvas",
            "auto"
          ],
          "description": "%configuration.ai-sidebar-terminal.pane.renderer.description%"
        }
      }
    }
  },
  "scripts": {
    "compile": "webpack",
    "compile:e2e": "tsc -p tsconfig.e2e.json",
    "watch": "webpack --watch",
    "package": "npm run compile && npx @vscode/vsce package -o build/extension.vsix",
    "lint": "eslint src --ext ts",
    "format": "prettier --write \"src/**/*.{ts,js,json,css,md}\"",
    "test": "vitest run",
    "pretest:e2e": "npm run compile && npm run compile:e2e",
    "test:e2e": "vscode-test",
    "test:all": "npm run test && npm run test:e2e",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build-and-install": "node scripts/build-and-install.js"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.2.0-beta.11",
    "preact": "^10.29.1"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.13",
    "@types/vscode": "^1.106.1",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.5.4",
    "jsdom": "^29.0.1",
    "mocha": "^11.7.5",
    "prettier": "^3.7.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.0"
  }
}
