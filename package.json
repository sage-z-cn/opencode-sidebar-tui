{
  "name": "opencode-sidebar-tui-sage",
  "displayName": "Opencode Sidebar TUI",
  "description": "Automatically render Opencode Sidebar Terminal in VS Code sidebar with full terminal support (fork of islee23520/opencode-sidebar-tui, with Windows compatibility improvements)",
  "version": "2.0.0",
  "publisher": "sagez",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.106.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "opencode",
    "terminal",
    "sidebar",
    "tui",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sage-z-cn/opencode-sidebar-tui.git"
  },
  "license": "MIT",
  "author": {
    "name": "sagez"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "ostContainer",
          "title": "Opencode Sidebar TUI",
          "icon": "resources/opencode-activity-bar.svg"
        }
      ]
    },
    "views": {
      "ostContainer": [
        {
          "id": "ost",
          "name": "Terminal",
          "type": "webview",
          "icon": "resources/opencode-activity-bar.svg",
          "initialOrder": 1
        }
      ]
    },
    "commands": [
      {
        "command": "ost.start",
        "title": "Start OpenCode",
        "category": "Opencode Sidebar TUI"
      },
      {
        "command": "ost.focus",
        "title": "Opencode Sidebar TUI: Focus Terminal"
      },
      {
        "command": "ost.sendToTerminal",
        "title": "Send to Active Terminal",
        "category": "Opencode Sidebar TUI"
      },
      {
        "command": "ost.sendAtMention",
        "title": "Send File Reference (@file)",
        "category": "Opencode Sidebar TUI"
      },
      {
        "command": "ost.sendAllOpenFiles",
        "title": "Send All Open File References",
        "category": "Opencode Sidebar TUI"
      },
      {
        "command": "ost.sendFileToTerminal",
        "title": "Send to OpenCode",
        "category": "Opencode Sidebar TUI"
      },
      {
        "command": "ost.paste",
        "title": "Paste",
        "category": "Opencode Sidebar TUI",
        "icon": "$(clippy)"
      },
      {
        "command": "ost.openInNewWindow",
        "title": "Open Tmux Session in New Window",
        "category": "Opencode Sidebar TUI",
        "icon": "$(empty-window)"
      },
      {
        "command": "ost.spawnForWorkspace",
        "title": "Spawn Tmux Session for Workspace",
        "category": "Opencode Sidebar TUI",
        "icon": "$(add)"
      },
      {
        "command": "ost.selectInstance",
        "title": "Select OpenCode Tmux Session",
        "category": "Opencode Sidebar TUI",
        "icon": "$(server-environment)"
      },
      {
        "command": "ost.switchTmuxSession",
        "title": "Switch Tmux Session",
        "category": "Opencode Sidebar TUI"
      },
      {
        "command": "ost.createTmuxSession",
        "title": "Opencode Sidebar TUI: Create Tmux Session"
      },
      {
        "command": "ost.browseTmuxSessions",
        "title": "Browse Tmux Sessions",
        "category": "Opencode Sidebar TUI",
        "icon": "$(server-environment)"
      },
      {
        "command": "ost.switchNativeShell",
        "title": "Switch to Native Shell",
        "category": "Opencode Sidebar TUI"
      },
      {
        "command": "ost.killNativeShell",
        "title": "Opencode Sidebar TUI: Kill Native Shell"
      },
      {
        "command": "ost.openTerminalManager",
        "title": "Opencode Sidebar TUI: Open Terminal Managers",
        "category": "Opencode Sidebar TUI",
        "icon": "$(server)"
      },
      {
        "command": "ost.toggleDashboard",
        "title": "Open Terminal Managers",
        "category": "Opencode Sidebar TUI",
        "icon": "$(dashboard)"
      },
      {
        "command": "ost.toggleTmuxCommandToolbar",
        "title": "Toggle Tmux Command Toolbar",
        "category": "Opencode Sidebar TUI",
        "icon": "$(list-tree)"
      },
      {
        "command": "ost.openDashboardInEditor",
        "title": "Open Terminal Managers in Editor",
        "category": "Opencode Sidebar TUI",
        "icon": "$(editor-layout)"
      },
      {
        "command": "ost.openTerminalInEditor",
        "title": "Open Terminal in Editor",
        "category": "Opencode Sidebar TUI",
        "icon": {
          "light": "resources/opencode-activity-bar.svg",
          "dark": "resources/opencode-activity-bar-dark.svg"
        }
      },
      {
        "command": "ost.restoreTerminalToSidebar",
        "title": "Restore Terminal to Sidebar",
        "category": "Opencode Sidebar TUI",
        "icon": "$(layout-sidebar-left)"
      },
      {
        "command": "ost.tmuxSwitchPane",
        "title": "Switch to Pane",
        "category": "Opencode Sidebar TUI",
        "icon": "$(check)"
      },
      {
        "command": "ost.tmuxSplitPaneH",
        "title": "Split Pane Horizontal",
        "category": "Opencode Sidebar TUI",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "ost.tmuxSplitPaneV",
        "title": "Split Pane Vertical",
        "category": "Opencode Sidebar TUI",
        "icon": "$(split-vertical)"
      },
      {
        "command": "ost.tmuxSplitPaneWithCommand",
        "title": "Split Pane with Command",
        "category": "Opencode Sidebar TUI",
        "icon": "$(terminal)"
      },
      {
        "command": "ost.tmuxSendTextToPane",
        "title": "Send Text to Pane",
        "category": "Opencode Sidebar TUI",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "ost.tmuxResizePane",
        "title": "Resize Pane",
        "category": "Opencode Sidebar TUI",
        "icon": "$(move)"
      },
      {
        "command": "ost.tmuxSwapPane",
        "title": "Swap Panes",
        "category": "Opencode Sidebar TUI",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "ost.tmuxKillPane",
        "title": "Kill Pane",
        "category": "Opencode Sidebar TUI",
        "icon": "$(trash)"
      },
      {
        "command": "ost.tmuxNextWindow",
        "title": "Next Window",
        "category": "Opencode Sidebar TUI",
        "icon": "$(chevron-right)"
      },
      {
        "command": "ost.tmuxPrevWindow",
        "title": "Previous Window",
        "category": "Opencode Sidebar TUI",
        "icon": "$(chevron-left)"
      },
      {
        "command": "ost.tmuxCreateWindow",
        "title": "Create Window",
        "category": "Opencode Sidebar TUI",
        "icon": "$(add)"
      },
      {
        "command": "ost.tmuxKillWindow",
        "title": "Kill Window",
        "category": "Opencode Sidebar TUI",
        "icon": "$(trash)"
      },
      {
        "command": "ost.tmuxSelectWindow",
        "title": "Select Window",
        "category": "Opencode Sidebar TUI",
        "icon": "$(list-selection)"
      },
      {
        "command": "ost.tmuxKillSession",
        "title": "Kill Session",
        "category": "Opencode Sidebar TUI",
        "icon": "$(trash)"
      },
      {
        "command": "ost.killTmuxSession",
        "title": "Opencode Sidebar TUI: Kill Tmux Session"
      },
      {
        "command": "ost.tmuxRefresh",
        "title": "Refresh Terminal Manager",
        "category": "Opencode Sidebar TUI",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [],
      "editor/title": [
        {
          "command": "ost.openTerminalManager",
          "group": "navigation",
          "when": "ost.active"
        },
        {
          "command": "ost.openTerminalInEditor",
          "group": "navigation@1",
          "when": "ost.active"
        }
      ],
      "explorer/context": [
        {
          "command": "ost.sendFileToTerminal",
          "group": "2_workspace",
          "when": "!explorerResourceIsFolder"
        },
        {
          "command": "ost.sendFileToTerminal",
          "group": "2_workspace",
          "when": "explorerResourceIsFolder"
        }
      ],
      "editor/context": [
        {
          "command": "ost.sendAtMention",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ost.sendAtMention",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "when": "editorTextFocus || terminalFocus"
      },
      {
        "command": "ost.sendAllOpenFiles",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a",
        "when": "editorTextFocus || terminalFocus"
      },
      {
        "command": "ost.browseTmuxSessions",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t",
        "when": "focusedView == 'ost'"
      },
      {
        "command": "-workbench.action.quickOpen",
        "key": "ctrl+p",
        "when": "focusedView == 'ost'"
      },
      {
        "command": "-workbench.action.quickOpenNavigateNextInFilePicker",
        "key": "ctrl+p",
        "when": "inFilesPicker && inQuickOpen"
      },
      {
        "command": "ost.paste",
        "key": "ctrl+v",
        "mac": "cmd+v",
        "when": "focusedView == 'ost'"
      },
      {
        "command": "ost.toggleTmuxCommandToolbar",
        "key": "ctrl+alt+m",
        "mac": "cmd+alt+m",
        "when": "focusedView == 'ost'"
      }
    ],
    "configuration": {
      "title": "Open Sidebar TUI",
      "properties": {
        "ost.fontSize": {
          "type": "number",
          "default": 14,
          "minimum": 6,
          "maximum": 25,
          "description": "Terminal font size in pixels"
        },
        "ost.fontFamily": {
          "type": "string",
          "default": "'JetBrainsMono Nerd Font', 'FiraCode Nerd Font', 'CascadiaCode NF', Menlo, monospace",
          "description": "Terminal font family (Nerd Font recommended for Powerline/glyph support)"
        },
        "ost.cursorBlink": {
          "type": "boolean",
          "default": true,
          "description": "Enable cursor blinking"
        },
        "ost.cursorStyle": {
          "type": "string",
          "default": "block",
          "enum": [
            "block",
            "underline",
            "bar"
          ],
          "description": "Cursor style"
        },
        "ost.scrollback": {
          "type": "number",
          "default": 10000,
          "minimum": 0,
          "maximum": 100000,
          "description": "Maximum number of lines in scrollback buffer"
        },
        "ost.autoFocusOnSend": {
          "type": "boolean",
          "default": true,
          "description": "Automatically focus the Open Sidebar after sending file references or text"
        },
        "ost.autoStartOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the AI tool when the sidebar is opened. When false, shows a tool selector each time."
        },
        "ost.shellPath": {
          "type": "string",
          "default": "",
          "description": "Custom shell path to use for the terminal. Leave empty to use VS Code's default shell. Useful for specifying PowerShell, Git Bash, or other shells on Windows."
        },
        "ost.shellArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Custom arguments to pass to the shell. Leave empty for automatic detection. Example: [\"/c\"] for cmd.exe or [\"-Command\"] for PowerShell."
        },
        "ost.sendKeybindingsToShell": {
          "type": "boolean",
          "default": true,
          "description": "Send Ctrl/Cmd + letter shortcuts (including Ctrl+P) directly to the sidebar terminal instead of letting VS Code intercept them. This extension's main purpose is running opencode (a TUI with its own keybindings), so the default is ON. You can turn it off if you prefer normal IDE shortcuts even when the sidebar terminal is focused. Control keys like Ctrl+C are always sent to the terminal."
        },
        "ost.showTmuxWindowControls": {
          "type": "boolean",
          "default": true,
          "description": "Show direct tmux session and window controls (+S, previous window, +W, next window) in the terminal toolbar. Turn this off to keep only the tmux command menu."
        },
        "ost.autoShareContext": {
          "type": "boolean",
          "default": true,
          "description": "Automatically share editor context (open files, selections) with OpenCode"
        },
        "ost.httpTimeout": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "maximum": 30000,
          "description": "HTTP API request timeout in milliseconds for communication with OpenCode"
        },
        "ost.enableHttpApi": {
          "type": "boolean",
          "default": true,
          "description": "Enable HTTP API for bidirectional communication between VS Code and OpenCode"
        },
        "ost.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "default": "info",
          "description": "Log output level for Opencode Sidebar TUI"
        },
        "ost.contextDebounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 5000,
          "description": "Debounce delay for context updates (ms)"
        },
        "ost.maxDiagnosticLength": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 2000,
          "description": "Maximum length of diagnostic messages"
        },
        "ost.enableAutoSpawn": {
          "type": "boolean",
          "default": true,
          "description": "Auto-spawn OpenCode if not running"
        },
        "ost.terminalBackend": {
          "type": "string",
          "default": "tmux",
          "enum": [
            "native",
            "tmux",
            "zellij"
          ],
          "enumDescriptions": [
            "Native terminal — basic shell only, no multiplexer features (panes, tabs, sessions)",
            "Tmux — full session, pane, and window management via tmux",
            "Zellij — full session, pane, and tab management via zellij"
          ],
          "description": "Select the terminal backend. Unavailable backends safely fall back to native.",
          "order": 1
        },
        "ost.collapseSecondaryBarOnEditorOpen": {
          "type": "boolean",
          "default": true,
          "description": "Close the secondary sidebar before moving the terminal into an editor group so the new editor tab gets the full workspace width."
        },
        "ost.codeActionSeverities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "error",
              "warning",
              "information",
              "hint"
            ]
          },
          "default": [
            "error",
            "warning"
          ],
          "description": "Diagnostic severities that trigger code actions"
        },
        "ost.aiTools": {
          "type": "array",
          "items": {
            "type": "object",
            "editPresentation": "editButton",
            "required": [
              "name",
              "label"
            ],
            "order": [
              "name",
              "label",
              "path",
              "args",
              "aliases",
              "operator"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Unique identifier (e.g. 'opencode', 'claude')"
              },
              "label": {
                "type": "string",
                "description": "Display name shown in the tool selector"
              },
              "path": {
                "type": "string",
                "description": "Path to the executable. Empty = resolve from PATH"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Arguments to pass when launching"
              },
              "aliases": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Alternative names that resolve to this tool"
              },
              "operator": {
                "type": "string",
                "description": "Operator ID for tool-specific launch and routing behavior"
              }
            }
          },
          "default": [
            {
              "name": "opencode",
              "label": "OpenCode",
              "path": "",
              "args": [],
              "operator": "opencode"
            },
            {
              "name": "claude",
              "label": "Claude",
              "path": "",
              "args": [],
              "aliases": [
                "claude"
              ],
              "operator": "claude"
            },
            {
              "name": "codex",
              "label": "Codex",
              "path": "",
              "args": [],
              "operator": "codex"
            }
          ],
          "description": "Configure AI coding tools. Use Add Item to add new tools, Edit to modify, Delete to remove."
        },
        "ost.defaultAiTool": {
          "type": "string",
          "default": "opencode",
          "description": "Name of the default AI tool to launch when creating a new terminal session"
        },
        "ost.promptAiToolOnSession": {
          "type": "boolean",
          "default": true,
          "description": "Show the AI tool selector popup when attaching to or creating a tmux/zellij session"
        },
        "ost.pane.defaultSplitDirection": {
          "type": "string",
          "default": "horizontal",
          "enum": ["horizontal", "vertical"],
          "description": "Default direction when splitting a terminal pane"
        },
        "ost.pane.focusOnClick": {
          "type": "boolean",
          "default": true,
          "description": "Focus a pane when clicking on it"
        },
        "ost.pane.showPaneActions": {
          "type": "boolean",
          "default": true,
          "description": "Show pane action buttons (split, close) in the terminal"
        },
        "ost.pane.renderer": {
          "type": "string",
          "default": "auto",
          "enum": ["webgl", "canvas", "auto"],
          "description": "Terminal renderer: webgl (fast), canvas (fallback), or auto (webgl up to 4 panes, then canvas)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "compile:e2e": "tsc -p tsconfig.e2e.json",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src --ext ts",
    "format": "prettier --write \"src/**/*.{ts,js,json,css,md}\"",
    "test": "vitest run",
    "pretest:e2e": "npm run compile && npm run compile:e2e",
    "test:e2e": "vscode-test",
    "test:all": "npm run test && npm run test:e2e",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build-and-install": "npx @vscode/vsce package -o build/extension.vsix && code --install-extension build/extension.vsix --force"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.2.0-beta.11",
    "preact": "^10.29.1"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.13",
    "@types/vscode": "^1.106.1",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.5.4",
    "jsdom": "^29.0.1",
    "mocha": "^11.7.5",
    "prettier": "^3.7.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.0"
  }
}

